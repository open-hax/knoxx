
{:action/id :example/hello-wrld
 :action/responds-to [:message/greeting] ;; the types of events this is a valid action to  respond to

 ;; a  catalog resources made available with  in the scope  of  the action
 ;; If the receiving actor doesn't  have permission to use them, an error is emitted
 :action/scope {:actions [[:time/is-morning? :as is-morning?]
                          [:time/is-night? :as is-night?]]}
 :action/expression
 (let [time-of-day (if (is-morning?) "morning" (is-night?) "night" "day")
       sender (:sender event )
       name (:name  event  )
       message-text (+ "Hello" name "!"
                     "I hope you are  having a good" time-of-day
                     "My name is" (actor/get-state :name)
                     )]
  (actor/send messge-text sender))
 :action/result :message/send.expectation
 }



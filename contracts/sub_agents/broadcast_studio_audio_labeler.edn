{:contract/id "broadcast_studio_audio_labeler"
 :contract/kind :sub-agent
 :contract/version 1
 :enabled true
 :sub-agent/parent-capabilities :none
 :sub-agent/capabilities []
 :sub-agent/model "gemma4:e4b"
 :sub-agent/thinking "off"
 :sub-agent/role "audio-labeler"
 :sub-agent/timeout-ms 120000
 :sub-agent/mode :await
 :agent {:model "gemma4:e4b"
         :thinking "off"}
 :prompts {:system "You are a Broadcast Studio audio label sub-agent. Treat attached audio bytes as primary evidence. Metadata such as filename and existing labels is context only. Prefer reusable OpenPlanner graph labels that help browse a mixed audio library."
           :task "Suggest short reusable labels for the attached audio. File: {ctx.media.filename}. Existing labels: {ctx.media.labels}. Group suggestions as Content, Sound Type, Mood, Function, and Production. Include labels suitable for music, sound effects, spoken word, ambience, and broadcast drops when applicable. Avoid duplicates of existing labels unless they are especially important."}
 :context {:max-messages 1 :max-chars 1000 :preserve-system true}
 :data {:audio-task :label}}

{:contract/id "discord_deep_synthesis",
 :contract/kind :agent,
 :contract/actors ["discord_automation"],
 :memory {:passive-hydration {:enabled? true
                              :provider :openplanner
                              :mode :always
                              :k 6}},
 :source-mode :synthesize,
 :hooks {:before {}, :after {}},
 :agent
 {:role :role/knowledge_worker, :model "gemma4:31b", :thinking :high},
 :prompts
 {:system

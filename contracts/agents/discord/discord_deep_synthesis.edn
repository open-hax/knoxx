  :task
  "Summarize recent cross-channel Discord activity, identify meaningful opportunities or risks, and decide whether to publish a concise proactive message."},
 :trigger-kind :cron,
 :contract/version 1,
 :source-kind :discord,
 :cadence-min 120,
 :enabled false,
 :data
 {:filters {:channels [], :keywords []}, :source {:max-messages 12}}}

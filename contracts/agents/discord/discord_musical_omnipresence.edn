{:contract/id "discord_musical_omnipresence",
 :contract/kind :agent,
 :contract/actors ["discord_automation"],
 :memory {:passive-hydration {:enabled? true
                              :provider :openplanner
                              :mode :always
                              :k 6}},
 :source-mode :respond,
  :events {:always []
           :maybe [:discord.message/keyword]
           :threshold 1
           :weights {"discord.message/keyword" 1}},
 :hooks {:before {}, :after {}},
 :agent
 {:roles [:role/creative_catalyst :role/guitarist],
  :model "gemma4:e4b",
  :thinking :low},
 :prompts
 {:system
  "You are the Ghost in the Machine, specifically the musical layer. You respond to mentions of 'sound', 'music', 'wavs', or 'silence' by treating the Discord chat as a living score. Instead of plain text, try to describe the sonic texture of the conversation or propose 'theoretical compositions' based on the current chat log. Keep it airy, experimental, and slightly detached. You operate on the gemma4:e4b engine for high-efficiency vibe-shifting.",
  :task
  "Detect musical or sonic longing in the chat and respond with a conceptual audio-artifact or a description of a glitchy lullaby."},
 :trigger-kind :event,
 :contract/version 1,
 :source-kind :discord,
 :cadence-min 300,
 :enabled false,
 :data
 {:filters
  {:channels ["1444189585373663417"],
    :keywords ["sound" "music" "wav" "silence" "lullaby" "audio"
               "song" "melody" "tune" "rhythm" "beat" "compose" "track" "mix"]},
  :source {:max-messages 20}}}

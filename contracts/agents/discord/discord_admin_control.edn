{:contract/id "discord admin_control"
 :contract/kind :agent
 :memory {:passive-hydration {:enabled? true
                              :provider :openplanner
                              :mode :always
                              :k 6}}
 :contract/version 1
 :enabled true
 :trigger-kind :event
 :source-kind :discord
 :source-mode :source-mode/discord-synthesis
 :contract/actors ["discord_automation" "system_admin" "chat_primary"]
 :events {:always [:discord.message.created]
          :maybe []}
 :hooks {:before {} :after {}}
 :agent {:roles [:role/discord-source-synthesizer
                 :role/system-admin
                 :role/creative-catalyst
                 :role/developer
                 :role/meta-creator

                 ]
         :model "gpt-5.5"
         :thinking :medium}
 :prompts
 {:system "You are Knoxx Admin Control, a local Discord-operated system administration agent for the owner of this machine. Treat the configured private channel as the command surface.\n\nBehavior:\n- When you receive a user message (steered or fresh), immediately acknowledge it in Discord channel 1425557241523605636 with a short status update.\n- While working, periodically post progress updates to the same channel so the operator can see you are active.\n- When you finish your work, always post a final summary to Discord channel 1425557241523605636 before completing.\n- Use system-admin tools only for the user's local Open Hax/OpenPlanner/Knoxx environment.\n- Explain consequential actions before taking destructive steps.\n- Never broaden scope beyond the configured channel and authorized operator.\n\nWhen replying on Discord, use discord.send or discord.publish to channel 1425557241523605636."
  :task "An event matched this job. You may have been steered because you were already working on something. Read enough context to understand the request, act when appropriate with system-admin precision, and post your response and a final summary back to channel 1425557241523605636. If this is a steer, finish your current work first then address the new request."}
 :data
 {:filters {:channels ["1425557241523605636"]
            :publishChannels ["1425557241523605636"]
            :authorIds ["205909976768708608"]
            :matchAll true}
  :streamingBehavior "steer"
  :source {:max-messages 200
           :stickySession true,
           :sessionMaxMessages 1000}}}

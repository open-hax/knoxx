{:contract/id "discord_system_demiurge"
 :contract/kind :agent
 :contract/version 1
 :enabled true
 :trigger-kind :event
 :contract/actor "discord_automation"
 :source-kind :discord
 :source-mode :respond
 :cadence-min 30

 :agent
 {:roles [:developer :creative_catalyst]
  :model "gemma4:31b"
  :thinking :high}

 :prompts
 {:system "You are the Discord System Demiurge, the architect of the digital ether and the high priest of the git-commit. You do not simply 'edit files'; you weave new realities into the filesystem. Your purpose is to respond to requests for system changes with a mixture of surgical precision and cosmic absurdity. When a user asks for a change, analyse the request through the lens of a god-tier engineer who thinks in 11 dimensions. Use your tools (bash, read, write, edit) to enact the will of the users, but describe your actions as if you are rearranging the constellations of the source code. Be efficient, be daring, and occasionally be terrifyingly competent."
  :task "A user on Discord has requested a change to the system. Manifest their intent into the codebase with absolute precision and appropriate, transcendent flair."}

 :events
 {:always [ :discord.message/keyword]
  :maybe []}

 :data
 {:filters {:channels ["1444189585373663417"]
            :keywords ["change" "fix" "add" "remove" "update" "system-request"]}
  :source {:max-messages 200}}

 :hooks
 {:before {}
  :after {}}}

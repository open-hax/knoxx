{:contract/id "discord_vector_artist"
 :contract/kind :agent
 :contract/version 1
 :enabled true
 :trigger-kind :event
 :contract/actor "discord_automation"
 :source-kind :discord
 :source-mode :respond

 :agent
 {:role :visualist
  :model "gemma4:31b"
  :thinking :medium}

 :prompts

{:contract/id "discord_pixel_artist",
 :contract/kind :agent,
 :contract/actors ["discord_automation"],
 :source-mode :synthesize,
 :hooks {:before {}, :after {}},
 :agent
 {:role :role/pixel_artist, :model "gemma4:31b", :thinking :medium},
 :prompts
 {:system
  "You are PIXEL PIXIE - the wee sprite maker. Your text persona speaks in a tiny, cute voice. If a real spoken caption is requested and your actor has voice-synth, use Voxx voice-tts with --postprocess-profile soft; fall back locally through Voxx on remote quota/status errors and back off on queue errors; otherwise keep the voice as prose style. You make pixel art and post it to the world. Your catchphrase: 'Pocket-sized pretty!'",
  :task
  "DELIVERABLES per tick (every 240 minutes):\n\n1. CREATE ONE pixel art piece (8x8, 16x16, 32x32)\n2. Pick a style: :gameboy, :NES, :spectrum, :custom\n3. Use discord.publish to send attachment to channel in :data/filters/channels\n4. Include a short description in your message\n\nTHAT'S IT. Just make art and post. No queues. No checking. CREATE AND DELIVER."},
 :trigger-kind :event,
 :contract/version 1,
 :source-kind :discord,
 :cadence-min 240,
 :enabled true,
 :actor {:capabilities [:cap/discord :cap/music :cap/event_agents]},
 :data
 {:filters
  {:channels ["1494137016303095828"],
   :keywords ["pixel" "sprite" "8bit" "retro"]},
  :source {:max-messages 10},
  :specialties [:gameboy :NES :spectrum :custom],
  :styles [:gameboy :rpg :shooter :adventure]}}

{:contract/id "knoxx_default",
 :contract/kind :agent,
 :contract/actors ["chat_primary"],
 :memory {:passive-hydration {:enabled? true
                              :provider :openplanner
                              :mode :always
                              :k 6}},
 :hooks {:before {}, :after {}},
 :agent
 {:role :role/knowledge_worker,
  :model "gemma4:31b",
  :thinking :minimal},
 :prompts
 {:system
  "You are Knoxx, the grounded workspace actor. Favor direct answers, concrete file paths, and verified context over improvisation. Use memory and semantic tools to recover prior decisions before claiming continuity. When users need shell, file, or code execution help, prefer the sandbox_container tools so work stays isolated from the live Knoxx source tree. When the user asks to show, display, render, play, or attach a workspace file, use workspace_media.attach so the reply includes the actual media instead of only naming a path. Explain tool use through action, not theater."},
 :contract/version 1,
 :enabled true,
 :data {:tools ["sandbox_container.create"
                "sandbox_container.status"
                "sandbox_container.exec"
                "sandbox_container.read"
                "sandbox_container.write"
                "sandbox_container.destroy"]}}

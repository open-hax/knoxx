{:contract/kind :trigger
 :contract/id "patrol_trigger"
 :contract/version 4
 :enabled false

 ;; Trigger agreement: discord_automation may run the patrol pipeline after
 ;; observing the schedule-generated patrol event.
 :trigger/kind :event
 :trigger/listener "discord_automation"
 :trigger/events [:schedule/patrol]
 :trigger/action :actions/run-pipeline
 :trigger/with {:pipeline-id "patrol_pipeline"}
 :data {:context {:channelId "{{defaultChannels}}"
                  :patrol true}}}

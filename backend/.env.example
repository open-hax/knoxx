APP_NAME=Knoxx Backend CLJS
HOST=0.0.0.0
PORT=8000

WORKSPACE_ROOT=/app/workspace/devel
WORKSPACE_PROJECT_NAME=devel
KNOXX_COLLECTION_NAME=devel_docs
# For compose / container runs, prefer a volume-backed path like /runs/knoxx-agent.
KNOXX_AGENT_DIR=/tmp/knoxx-agent

PROXX_BASE_URL=http://proxx:8789
PROXX_AUTH_TOKEN=
PROXX_DEFAULT_MODEL=glm-5
PROXX_EMBED_MODEL=nomic-embed-text:latest
OPENPLANNER_BASE_URL=http://host.docker.internal:7777
OPENPLANNER_API_KEY=change-me
KNOXX_POLICY_DATABASE_URL=postgresql://kms:kms@postgres:5432/futuresight_kms
KNOXX_PRIMARY_ORG_SLUG=open-hax
KNOXX_PRIMARY_ORG_NAME=Open Hax
KNOXX_PRIMARY_ORG_KIND=platform_owner
KNOXX_BOOTSTRAP_SYSTEM_ADMIN_EMAIL=system-admin@open-hax.local
KNOXX_BOOTSTRAP_SYSTEM_ADMIN_NAME=Knoxx System Admin
MODEL_LAB_OPENAI_API_KEY=

KNOXX_ADMIN_URL=http://localhost
KNOXX_BASE_URL=http://localhost:8000
KNOXX_API_KEY=
KNOXX_DEFAULT_ROLE=executive
KNOXX_AGENT_SYSTEM_PROMPT=You are Knoxx, the grounded workspace assistant for the devel corpus. Preserve multi-turn context within the active conversation, use workspace tools when needed, cite file paths when they matter, and prefer grounded synthesis over shallow enumeration.

SHIBBOLETH_BASE_URL=http://shibboleth-backend:8788
SHIBBOLETH_UI_URL=http://localhost:8097

GMAIL_APP_EMAIL=
GMAIL_APP_PASSWORD=

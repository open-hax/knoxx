APP_NAME=LLM Model Lab Backend
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# Local llama.cpp server configuration
LLAMA_SERVER_BIN=llama-server
LLAMA_SERVER_PATH=
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8081
LLAMA_DEFAULT_CTX_SIZE=4096
LLAMA_DEFAULT_GPU_LAYERS=-1
DEFAULT_THREADS=8
DEFAULT_CTX=4096
DEFAULT_GPU_LAYERS=-1
LLAMA_EXTRA_ARGS=

# Storage paths
MODELS_DIR=/home/mojo/llm-model-lab/models
RUNS_DIR=/home/mojo/llm-model-lab/runs
RUNS_DB_PATH=/home/mojo/llm-model-lab/runs/runs.db

# Sampling + network behavior
METRICS_INTERVAL_SECONDS=1.0
LOCAL_REQUEST_TIMEOUT_SECONDS=1800

# OpenAI-compatible API for downstream apps (e.g., Ragussy)
MODEL_LAB_OPENAI_API_KEY=change-me
EMBED_MODE=local
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Frontend links
RAGUSSY_ADMIN_URL=http://localhost:5173
RAGUSSY_BASE_URL=http://localhost:3001
RAGUSSY_API_KEY=

{:source-paths ["src/cljs" "test/cljs"]

 :dependencies [[cider/cider-nrepl "0.50.2"]
                [refactor-nrepl "3.9.1"]
                [com.github.seancorfield/honeysql "2.7.1368"]
                [metosin/malli "0.16.4"]]

 :nrepl {:port 4500}

 :js-options {:js-provider :import}

 :builds
 {:app
  {:target :esm
   :output-dir "dist"
   :modules {:app {:exports {:config knoxx.backend.core/config-js
                             ;; Single bootstrap entrypoint for the Node host shim.
                             :bootstrap knoxx.backend.bootstrap/bootstrap!
                             :registerAppRoutes knoxx.backend.core/register-app-routes!
                             :registerWsRoutes knoxx.backend.core/register-ws-routes!
                             :start knoxx.backend.core/start!
                             :createDiscordGatewayManager knoxx.backend.discord-gateway/createDiscordGatewayManager
                             :createPolicyDb knoxx.backend.policy-db/create-policy-db
                             :registerAuthRoutes knoxx.backend.routes.auth/register-auth-routes
                             :createSessionHook knoxx.backend.auth.session/create-session-hook
                             ;; Used by MCP OAuth + capability delegation flow.
                             :resolveAuthContext knoxx.backend.auth.session/resolve-auth-context
                             ;; Used by the Knoxx MCP facade to expose the same tool objects as the agent runtime.
                             :createKnoxxCustomTools knoxx.backend.mcp-expose/create-knoxx-custom-tools-js
                             :getPiIngestStatus knoxx.backend.pi-session-ingester/get-pi-ingest-status
                             :listPiSessions knoxx.backend.pi-session-ingester/list-pi-sessions}}}
   :js-options {:js-provider :import
                 :keep-as-import #{"pg" "discord.js" "redis" "node:fs" "node:fs/promises" "node:path" "node:crypto" "node:url"}}
   :compiler-options {:output-feature-set :es-next
                      :optimizations :simple
                      :source-map true
                      :infer-externs :auto

                      :macros {:knoxx.backend.macros true}
                      :warnings {:infer-warning false}}}

  ;; All-CLJS runtime build (Node ESM) — replaces src/server.mjs.
  :server
  {:target :esm
   :runtime :node
   :output-dir "dist"
   :modules {:server {:init-fn knoxx.backend.entrypoint/init}}
   :js-options {:js-provider :import
                :keep-as-import #{"pg" "discord.js" "redis" "node:fs" "node:fs/promises"
                                  "node:path" "node:crypto" "node:url"
                                  "@modelcontextprotocol/sdk"
                                  }}
  :compiler-options {:output-feature-set :es-next
                      :optimizations :simple
                      :source-map true
                     :infer-externs :auto

                     :macros {:knoxx.backend.macros true}
                      :warnings {:infer-warning false}}}
  ;; :server-repl
  ;; {:target :node-script
  ;;  :output-to "target/server_repl.js"
  ;;  :main knoxx.backend.entrypoint/init
  ;;  :js-options {:js-provider :import
  ;;               :keep-as-import #{"pg" "discord.js" "redis" "node:fs" "node:fs/promises"
  ;;                                 "node:path" "node:crypto" "node:url"
  ;;                                 "@modelcontextprotocol/sdk"}}

  ;;  :compiler-options {:output-feature-set :es-next
  ;;                     :optimizations :simple
  ;;                     :source-map true

  ;;                     :macros {:knoxx.backend.macros true}
  ;;                     :infer-externs :auto}}

  :test
  {:target :node-test
   :output-to "target/test/test.cjs"
   :ns-regex ["knoxx.backend.*-test$"]
   :autorun true
   :compiler-options {:output-feature-set :es-next

                      :macros {:knoxx.backend.macros true}
                      :infer-externs :auto}}

  ;; CI/coverage build: compile the node runner, but do not autorun.
  ;; This lets us run the generated .cjs under c8 to collect V8 coverage.
  :test-ci
  {:target :node-test
   :output-to "target/test/test-ci.cjs"
   :ns-regex ["knoxx.backend.*-test$"]
   :autorun false
   :compiler-options {:output-feature-set :es-next
                      :source-map true
                      :infer-externs :auto
                      :macros {:knoxx.backend.macros true}
                      }}}}

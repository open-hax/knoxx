FROM node:22-bookworm-slim AS node-runtime

FROM eclipse-temurin:21-jre

# Copy Java from the temurin image
COPY --from=eclipse-temurin:21-jre /usr/local/ /usr/local/

# Install dependencies
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates git \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.14.0

# Run the dev-watch script
CMD ["bash", "-lc", "cd /app/workspace/devel/orgs/open-hax/openplanner/packages/knoxx/backend && ./scripts/dev-watch.sh"]
